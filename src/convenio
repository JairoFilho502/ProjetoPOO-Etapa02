import java.util.ArrayList;
import java.util.List;

public class Convenio {

    private String nome;
    private double percentualCobertura; // ex: 0.40 = 40%
    private List<String> especialidadesCobertas;

    // construtor basico - so nome
    public Convenio(String nome) {
        this.nome                  = nome;
        this.percentualCobertura   = 0.0;
        this.especialidadesCobertas = new ArrayList<>();
    }

    // construtor com percentual ja definido
    public Convenio(String nome, double percentualCobertura) {
        this.nome                  = nome;
        this.percentualCobertura   = percentualCobertura;
        this.especialidadesCobertas = new ArrayList<>();
    }

    // --- getters ---
    public String           getNome()                  { return nome; }
    public double           getPercentualCobertura()   { return percentualCobertura; }
    public List<String>     getEspecialidadesCobertas(){ return especialidadesCobertas; }

    // --- setters ---
    public void setNome(String nome)                           { this.nome = nome; }
    public void setPercentualCobertura(double percentualCobertura) {
        this.percentualCobertura = percentualCobertura;
    }

    // adiciona especialidade coberta pelo convenio
    public void adicionarEspecialidade(String especialidade) {
        if (especialidade != null && !especialidade.trim().isEmpty()) {
            especialidadesCobertas.add(especialidade.toLowerCase().trim());
        }
    }

    // verifica se a especialidade tem cobertura - usado pelo Integrante 5 (Jornada 20)
    public boolean possuiCoberturaEspecialidade(String especialidade) {
        if (especialidade == null) return false;
        return especialidadesCobertas.contains(especialidade.toLowerCase().trim());
    }

    // lista as especialidades na tela
    public void listarEspecialidades() {
        if (especialidadesCobertas.isEmpty()) {
            System.out.println("Nenhuma especialidade cadastrada para " + nome + ".");
            return;
        }
        System.out.println("Especialidades cobertas por " + nome + ":");
        for (int i = 0; i < especialidadesCobertas.size(); i++) {
            System.out.println("  - " + especialidadesCobertas.get(i));
        }
    }

    public String exibirResumo() {
        int cobertura = (int)(percentualCobertura * 100);
        return "Convenio: " + nome + " | Cobertura: " + cobertura
                + "% | Especialidades: " + especialidadesCobertas.size();
    }
}
